rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /tasks/{taskId} {
      // All authenticated users can see all tasks
      allow read: if isAuthenticated();

      // Only owner can create with their ID
      allow create: if isOwner(request.resource.data.userId);

      // Only owner can update or delete
      allow update, delete: if isOwner(resource.data.userId);
    }

    match /categories/{categoryId} {
      // Only owner can read/write their categories
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerUid == request.auth.uid);
      
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      
      allow update, delete: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
    }

    // Fallback for other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}